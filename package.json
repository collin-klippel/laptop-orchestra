{
  "name": "laptop-orchestra",
  "version": "0.1.0",
  "private": true,
  "description": "A networked playground for laptop ensembles. Sign in, see who else is online.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "postinstall": "node scripts/ensure-esbuild-platform.mjs",
    "prepare": "husky",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w server && npm run build -w client",
    "verify": "npm run lint && npm run knip && npm run typecheck && npm run test:coverage && npm run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "biome check client server shared",
    "lint:fix": "biome check --write --unsafe client server shared",
    "format": "biome format --write client server shared",
    "knip": "knip --no-exit-code",
    "knip:fix": "knip --fix --format --no-progress --no-exit-code",
    "link:aleatoric": "npm link aleatoric -w @laptop-orchestra/client",
    "unlink:aleatoric": "npm unlink aleatoric -w @laptop-orchestra/client && npm install"
  },
  "lint-staged": {
    "*": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.5"
  }
}
